# API-ключ к системе Smart Cargo ML. Выдаётся командой Smart ML.
# В Vercel задаётся как Environment Variable для окружений Production
# и Preview. Локально — скопируйте этот файл в .env.local и подставьте
# значение.
SMARTML_API_KEY=

# Базовый URL Smart ML API. По умолчанию используется
# https://routelist-sc.fly.dev (прод). Для тестового стенда задайте
# https://test-routelist-sc.fly.dev (или другой адрес, выданный Smart ML).
# В Vercel — переменная окружения, в локалке — .env.local.
SMARTML_API_BASE=

# Базовый URL для УВЭД-эндпоинтов Smart ML (публичные, дёргаются прямо
# с клиента, без X-API-Key). По умолчанию — тестовая среда. Этот URL
# попадает в клиентский бандл (префикс VITE_*), не клади сюда секреты.
VITE_SMARTML_BASE=https://test-routelist-sc.fly.dev
