# API-ключ к системе Smart Cargo ML для эндпоинтов /api/v1/external/*.
# Выдаётся командой Smart ML. Тестовая БД — копия прода, поэтому
# тестовый ключ = боевой. В Vercel задаётся как Environment Variable
# для окружений Production и Preview. Локально — скопируйте этот файл
# в .env.local и подставьте значение.
SMARTML_API_KEY=

# Базовый URL Smart ML API.
#   Тест-стенд: https://test-routelist-smartcargo.codecraft.kz
#   Прод:       https://routelist.smartcargo.global
# По умолчанию код использует тест-стенд. В Vercel — Environment
# Variable, в локалке — .env.local.
SMARTML_API_BASE=

# Используется ТОЛЬКО для PDF-ссылки (top-level navigation, CORS
# неприменим). Прокси-функции /api/uved/* читают свой backend из
# SMARTML_API_BASE.
VITE_SMARTML_BASE=https://test-routelist-smartcargo.codecraft.kz
